{
  "name": "@reelforge/video-engine",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    },
    "./render-server": {
      "types": "./dist/render-server.d.ts",
      "default": "./dist/render-server.js"
    }
  },
  "typesVersions": {
    "*": {
      "render-server": ["dist/render-server.d.ts"]
    }
  },
  "scripts": {
    "build": "tsc -b tsconfig.json",
    "typecheck": "tsc -b tsconfig.json --pretty false"
  },
  "dependencies": {
    "@reelforge/caption-engine": "file:../caption-engine",
    "@reelforge/cinematic-engine": "file:../cinematic-engine",
    "@reelforge/story-engine": "file:../story-engine",
    "@reelforge/templates": "file:../templates"
  },
  "devDependencies": {
    "typescript": "^5.7.0"
  }
}

