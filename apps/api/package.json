{
  "name": "@reelforge/api",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "tsx watch --tsconfig tsconfig.dev.json src/index.ts",
    "build": "tsc -b tsconfig.json",
    "start": "node dist/apps/api/src/index.js",
    "typecheck": "tsc --noEmit -p tsconfig.json",
    "intake:scan": "tsx --tsconfig tsconfig.dev.json src/cli/intake-scan.ts",
    "intake:import-approved": "tsx --tsconfig tsconfig.dev.json src/cli/intake-import-approved.ts"
  },
  "dependencies": {
    "@prisma/client": "6.16.0",
    "@reelforge/audio-engine": "file:../../packages/audio-engine",
    "@reelforge/caption-engine": "file:../../packages/caption-engine",
    "@reelforge/cinematic-engine": "file:../../packages/cinematic-engine",
    "@reelforge/narration-engine": "file:../../packages/narration-engine",
    "@reelforge/prompt-engine": "file:../../packages/prompt-engine",
    "@reelforge/hybrid-visual-engine": "file:../../packages/hybrid-visual-engine",
    "@reelforge/media-collector": "file:../../packages/media-collector",
    "@reelforge/research-collector": "file:../../packages/research-collector",
    "@reelforge/story-engine": "file:../../packages/story-engine",
    "@reelforge/templates": "file:../../packages/templates",
    "@reelforge/video-engine": "file:../../packages/video-engine"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "tsx": "^4.19.2",
    "typescript": "^5.7.0"
  }
}

